
class car:
    def __init__(self, type):
        self.type= type

    @staticmethod
    def start():
        print("Car is starting")

    @staticmethod
    def stop():
        print("Car is stopping")

class BMW(car):
   def __init__(self, name, type):
         super().__init__(type)
         self.name= name
         super().start()

car1= BMW("BMW", "Sedan")
print(car1.type)
print(car1.name)

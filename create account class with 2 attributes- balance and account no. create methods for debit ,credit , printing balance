

class account:
    def __init__(self, bal, acc):
        self.balance = bal
        self.account_no = acc

     # Return balance
    def get_balance(self):
        return self.balance

    #debit method
    def debit(self, amount):
        self.balance -= amount
        print("rs.", amount, "was debited")
        print("total balance= ", self.get_balance())

    #credit method
    def credit(self, amount):
        self.balance += amount
        print("rs.", amount, "was credited")
        print("total balance= ", self.get_balance())


acc1= account(10000, 1233456)
acc1.debit(2345)
acc1.credit(876)
